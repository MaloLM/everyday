{
  "name": "everyday",
  "version": "1.1.0",
  "description": "a local electron app for everyday use cases",
  "main": "./dist/main.bundle.js",
  "scripts": {
    "start": "electron ./dist/main.bundle.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"wait-on http://localhost:8080 && npm run dev:main\"",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js --mode development",
    "dev:main": "electron ./dist/main.bundle.js",
    "pack": "electron-builder --dir --mac",
    "dist": "electron-builder --win --mac --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:main": "vitest run --project main",
    "test:renderer": "vitest run --project renderer",
    "test:tam": "vitest run --project renderer tam-form TargetAllocation",
    "test:nw": "vitest run --project renderer nw-form NetWorthAssessment",
    "test:shared": "vitest run --project renderer Button Card Layout Sidebar NumberField TextField SliderField SelectorField Loading ErrorMessage AppContext",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Malo Le Mestre",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chart.js": "^2.9.41",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.9.0",
    "electron": "~39.8.7",
    "electron-builder": "^26.0.0",
    "html-webpack-plugin": "^5.6.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.33",
    "postcss-loader": "^7.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.1.0",
    "formik": "^2.4.5",
    "lucide-react": "^0.316.0",
    "react-chartjs-2": "^5.2.0",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.21.3",
    "remark-gfm": "^4.0.1",
    "yup": "^1.3.3"
  },
  "build": {
    "appId": "io.dopee.everyday",
    "productName": "Everyday",
    "directories": {
      "output": "dist_packaged"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "dist/icons/logo.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "dist/icons/logo.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "dist/icons/logo.png"
    }
  }
}
